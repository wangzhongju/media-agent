root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{c,cc,cpp,cxx,h,hh,hpp,hxx,proto,cmake,sh,py,yml,yaml,json,toml,md,txt,gitignore,gitattributes,editorconfig}]
indent_size = 2

[Makefile]
indent_style = tab
