#!/usr/bin/make -f

export DH_VERBOSE = 1
export DH_COMPAT = 12

%:
	dh $@ --buildsystem=cmake --builddirectory=build

override_dh_auto_configure:
	dh_auto_configure -- -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/opt/media_agent

override_dh_auto_install:
	dh_auto_install --destdir=$(CURDIR)/debian/media-agent
