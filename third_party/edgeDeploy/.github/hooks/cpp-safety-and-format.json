{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "linux": "bash .github/hooks/block-sensitive-paths.sh",
        "timeout": 15
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "linux": "bash .github/hooks/format-changed-cpp.sh",
        "timeout": 30
      }
    ]
  }
}